# ──────────────────────────────────────────────
# 대견할지도 환경변수 설정 파일
# 이 파일을 복사해서 .env 파일을 만들고 값을 채워주세요.
# cp .env.example .env
# ──────────────────────────────────────────────

# Supabase (https://supabase.com 프로젝트 설정 > API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# 네이버 지도 API (https://console.ncloud.com → Application 등록)
VITE_NAVER_CLIENT_ID=your-naver-client-id

# Gemini API (https://aistudio.google.com/app/apikey)
# AIGrowthCare의 AI 분석 기능에 사용됩니다.
VITE_GEMINI_API_KEY=your-gemini-api-key

# 관리자 설정 (배포 전 반드시 변경하세요)
VITE_ADMIN_ID=your-admin-id
VITE_ADMIN_PW=your-secure-password
